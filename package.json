{
    "name": "open-worship-app",
    "description": "Fully Open-Source and completely free forever for worship service.",
    "author": "Open Worship Foundation <owf2025@gmail.com> (https://github.com/orgs/OpenWorshipApp/people)",
    "gitRepository": "https://github.com/OpenWorshipApp/open-worship-app-dt",
    "homepage": "https://www.openworship.app",
    "version": "2026.06.20",
    "type": "commonjs",
    "main": "./electron-build/electron/index.js",
    "scripts": {
        "dev": "concurrently -k \"npm run vite:dev\" \"npm run electron:build && npm run electron\"",
        "electron:build": "node extra-work/rmdir.mjs electron-build && tsc -p electron.tsconfig.json && node extra-work/copy-build.mjs && node extra-work/build-info.mjs",
        "electron:build:watch": "tsc -p electron.tsconfig.json -w",
        "electron": "cross-env NODE_ENV=development electron .",
        "electron:watch": "nodemon --exec \"npm run electron\" --watch electron-build",
        "electron:dev": "npm run electron:build && concurrently -k \"npm run electron:build:watch\" \"npm run electron:watch\"",
        "build": "npm run vite:build && npm run electron:build",
        "pack:mac": "npm run build && electron-builder build --mac",
        "pack:linux": "npm run build && electron-builder build --linux && npm run pack:linux:rpm",
        "pack:linux:rpm": "node extra-work/build-fedora-rpm.mjs",
        "pack:linux:32": "cross-env FORCE_ARCH_32=true npm run build && electron-builder build --linux --ia32",
        "pack:win": "npm run build && electron-builder build --win",
        "pack:win:32": "cross-env FORCE_ARCH_32=true npm run build && electron-builder build --win --ia32",
        "test": "vitest run --config vitest.config.ts",
        "test:watch": "vitest --config vitest.config.ts",
        "test:electron": "vitest run --config vitest.electron.config.ts",
        "test:electron:watch": "vitest --config vitest.electron.config.ts",
        "test:coverage": "vitest run --config vitest.config.ts --coverage --coverage.reporter=html --coverage.reporter=text-summary --coverage.reportsDirectory=coverage",
        "test:electron:coverage": "vitest run --config vitest.electron.config.ts --coverage --coverage.reporter=html --coverage.reporter=text-summary --coverage.reportsDirectory=coverage-electron",
        "test:all:coverage": "npm run test:coverage && npm run test:electron:coverage",
        "test:all": "npm run test && npm run test:electron",
        "test:e2e": "npm run build && playwright test",
        "test:e2e:headed": "npm run build && playwright test --headed",
        "vite:dev": "vite",
        "vite:build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build",
        "lint:pre": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\" \"electron/**/*.ts\"",
        "lint:all:error": "tsc --noEmit --skipLibCheck",
        "lint:es": "eslint src/**/*.ts* electron/**/*.ts --ignore-pattern \"src/**/*.test.ts*\" --ignore-pattern \"src/**/*.spec.ts*\" --max-warnings 0 --no-warn-ignored",
        "lint": "npm run test:all && npm run lint:all:error && npm run lint:pre && npm run lint:es && npm run build",
        "dc:err": "depcruise src --include-only \"^src\" --output-type err-html > dc-dependency-graph/errors.html",
        "release:version": "node extra-work/setTodayVersion.mjs && npm install",
        "release:tag": "bash extra-work/release-tag.sh",
        "release": "bash extra-work/release.sh",
        "install": "bash extra-work/bin-helper/build.sh"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "build": {
        "productName": "Open Worship app",
        "appId": "app.openworship.desktop",
        "nodeGypRebuild": "false",
        "files": [
            "electron-build/**/*",
            "dist/**/*",
            "package.json"
        ],
        "asarUnpack": [
            "electron-build/**/*",
            "dist/**/*.gz.bundle"
        ],
        "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
        "dmg": {
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        },
        "win": {
            "target": [
                "nsis",
                "zip"
            ]
        },
        "linux": {
            "target": [
                "deb",
                "AppImage"
            ],
            "category": "Productivity",
            "artifactName": "${name}_${version}_${arch}.${ext}"
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.productivity",
            "minimumSystemVersion": "10.0",
            "extendInfo": {
                "NSCameraUsageDescription": "This app requires camera access to use as background video."
            }
        },
        "directories": {
            "buildResources": "resources",
            "output": "release"
        },
        "nsis": {
            "allowToChangeInstallationDirectory": true,
            "oneClick": false,
            "license": "LICENSE.txt"
        }
    },
    "engines": {
        "node": ">=18.16.0"
    },
    "devDependencies": {
        "@anthropic-ai/sdk": "^0.105.0",
        "@aws-sdk/client-cloudfront": "^3.1073.0",
        "@aws-sdk/client-s3": "^3.1073.0",
        "@eslint/js": "^10.0.1",
        "@lexical/dragon": "^0.45.0",
        "@lexical/history": "^0.45.0",
        "@lexical/rich-text": "^0.45.0",
        "@playwright/test": "^1.61.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@types/diff": "^7.0.2",
        "@types/dompurify": "^3.0.5",
        "@types/markdown-it": "^14.1.2",
        "@types/node": "^26.0.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/tar": "^6.1.13",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "@vitejs/plugin-react-swc": "^4.3.1",
        "@vitest/coverage-v8": "^4.1.9",
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "concurrently": "^10.0.3",
        "cross-env": "^10.1.0",
        "dependency-cruiser": "^17.4.3",
        "diff": "^9.0.0",
        "electron": "^42.4.1",
        "electron-builder": "^25.1.8",
        "eslint": "^10.5.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "json-schema-library": "^11.6.1",
        "lexical": "^0.45.0",
        "markdown-it": "^14.2.0",
        "markdown-it-music": "^2.0.6",
        "moment-timezone": "^0.6.2",
        "monaco-editor": "^0.55.1",
        "node-api-dotnet": "^0.9.21",
        "nodemon": "^3.1.14",
        "openai": "^6.44.0",
        "prettier": "^3.8.4",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "sass": "^1.101.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "font-list": "^2.0.1",
        "libreoffice-convert": "^1.8.1",
        "lw-share": "^0.0.7",
        "mupdf": "^1.27.0",
        "tar": "^7.5.16",
        "yt-dlp-wrap": "^2.3.12"
    }
}
